{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "factoryName": {
            "type": "string",
            "metadata": "Data Factory name",
            "defaultValue": "project3-adf-databricks"
        },
        "AzureDatabricks1_accessToken": {
            "type": "secureString",
            "metadata": "Secure string for 'accessToken' of 'AzureDatabricks1'"
        },
        "LS_Azure_SQL_Project3_password": {
            "type": "secureString",
            "metadata": "Secure string for 'password' of 'LS_Azure_SQL_Project3'"
        },
        "LS_Azure_SQL_Project3_properties_typeProperties_server": {
            "type": "string",
            "defaultValue": "project3-sqlserver.database.windows.net"
        },
        "LS_Azure_SQL_Project3_properties_typeProperties_database": {
            "type": "string",
            "defaultValue": "project3-sqldb"
        },
        "LS_Azure_SQL_Project3_properties_typeProperties_userName": {
            "type": "string",
            "defaultValue": "admin-project3"
        },
        "containerUri": {
            "type": "string",
            "metadata": "URI to storage account containing linked ARM templates"
        },
        "containerSasToken": {
            "type": "string",
            "metadata": "Sas token to storage account containing linked ARM templates"
        }
    },
    "variables": {
        "factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
    },
    "resources": [
        {
            "name": "project3-adf-databricks_ArmTemplate_0",
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2024-03-01",
            "properties": {
                "mode": "incremental",
                "templateLink": {
                    "uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
                    "contentVersion": "1.0.0.0"
                },
                "parameters": {
                    "factoryName": {
                        "value": "[parameters('factoryName')]"
                    },
                    "AzureDatabricks1_accessToken": {
                        "value": "[parameters('AzureDatabricks1_accessToken')]"
                    },
                    "LS_Azure_SQL_Project3_password": {
                        "value": "[parameters('LS_Azure_SQL_Project3_password')]"
                    },
                    "LS_Azure_SQL_Project3_properties_typeProperties_server": {
                        "value": "[parameters('LS_Azure_SQL_Project3_properties_typeProperties_server')]"
                    },
                    "LS_Azure_SQL_Project3_properties_typeProperties_database": {
                        "value": "[parameters('LS_Azure_SQL_Project3_properties_typeProperties_database')]"
                    },
                    "LS_Azure_SQL_Project3_properties_typeProperties_userName": {
                        "value": "[parameters('LS_Azure_SQL_Project3_properties_typeProperties_userName')]"
                    }
                }
            },
            "dependsOn": []
        }
    ]
}